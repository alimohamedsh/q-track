APP_NAME="Q-TRACK"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Railway: نفس الرابط العام بالـhttps (مهم للجلسات وCSRF وFilament)
APP_URL=https://your-service.up.railway.app

# --- Railway (Variables في لوحة التحكم) ---
# SESSION_SECURE_COOKIE=true
# LOG_CHANNEL=stderr
# إن وُجدت MySQL على Railway: اربط الخدمة أو انسخ MYSQL_* / DATABASE_URL حسب القالب
# CACHE_STORE=file أو database (لو database + migrate لجدول cache)
# QUEUE_CONNECTION=sync (أو redis لو أضفت Redis على Railway)

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
# With Laravel Sail use DB_HOST=mysql (service name). On the host machine use 127.0.0.1 + FORWARD_DB_PORT.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

# Broadcast & Cache
BROADCAST_DRIVER=log
# Use "file" locally so artisan cache:clear works without a running DB (production may use database/redis)
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail Configuration (Railway usually uses external SMTP)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Forward Ports (Keep them for local dev reference)
FORWARD_MAILPIT_PORT=1027
FORWARD_MAILPIT_DASHBOARD_PORT=8027
VITE_PORT=5173